<mujoco model="g1_rubiks_cube_scene">

  <compiler angle="radian" meshdir="../.."/>

  <option timestep="0.002" gravity="0 0 -9.81" solver="CG" iterations="50" tolerance="1e-10"/>

  <visual>
    <quality shadowsize="4096" offsamples="8"/>
    <map shadowclip="0.5" shadowscale="1.5" znear="0.01"/>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0.1 0.1 0.1"/>
    <global offwidth="640" offheight="480"/>
  </visual>

  <asset>
    <!-- Floor: checker pattern -->
    <texture type="2d" name="tex_floor"
             builtin="checker"
             rgb1="0.10 0.10 0.12"
             rgb2="0.16 0.16 0.20"
             width="512" height="512"
             mark="edge" markrgb="0.25 0.25 0.30"/>
    <material name="mat_floor" texture="tex_floor"
              texrepeat="4 4" texuniform="true" reflectance="0.05"/>

    <!-- Table: plain white, matching the real training footage -->
    <material name="mat_table" rgba="0.92 0.92 0.90 1.0" shininess="0.15" specular="0.15"/>

    <!-- Table legs: dark metal -->
    <material name="mat_metal" rgba="0.25 0.25 0.28 1.0" shininess="0.6" specular="0.5"/>

    <!-- Placement plate/tray: matte black, matching the real training footage
         (task instruction: "...put it in the plate") -->
    <material name="mat_plate" rgba="0.08 0.08 0.09 1.0" shininess="0.5" specular="0.4"/>

    <!-- Plain cube: solid color, distinct from the white table and black plate -->
    <material name="mat_cube_body" rgba="0.85 0.25 0.05 1.0" shininess="0.3" specular="0.2"/>

    <!-- IK target marker: bright cyan sphere -->
    <material name="mat_target" rgba="0.0 0.9 0.9 0.7" shininess="0.8" specular="0.6"/>
  </asset>

  <worldbody>
    <!-- Lights -->
    <light name="light_key" directional="true" diffuse="0.85 0.85 0.85" specular="0.30 0.30 0.30"
           pos="1.0 -0.5 4.0" dir="-0.3 0.2 -1" castshadow="true"/>

    <light name="light_fill" directional="true" diffuse="0.35 0.35 0.40" specular="0.05 0.05 0.05"
           pos="-2 1 3" dir="1 -0.5 -1" castshadow="false"/>

    <!-- Cameras -->
    <camera name="cam_front" pos="2.2 0.0 1.1" xyaxes="-1 0 0  0 0 1" fovy="50"/>
    <camera name="cam_side" pos="0.0 2.5 1.2" xyaxes="1 0 0  0 -0.3 1" fovy="45"/>
    <camera name="cam_top" pos="0.5 0.0 2.8" xyaxes="1 0 0  0 1 0" fovy="55"/>
    <camera name="cam_wrist" pos="0.5 0.35 0.95" target="rubiks_cube" fovy="60"/>

    <!-- Close, steep-down ego view approximating the real training camera's
         framing (see dataset_g1/brainco_pick/G1_Brainco_GraspRubiksCube_Dataset
         videos: both hands + table fill almost the whole frame, camera looks
         down and away from the robot's body). World-fixed rather than bolted
         to torso_link -- fine since the waist is now locked in place anyway. -->
    <camera name="head_camera_close" pos="0.2435 0.0340 1.4328"
            xyaxes="0.0000 -1.0000 0.0000  0.9397 0.0000 0.3420" fovy="65"/>

    <!-- Floor -->
    <geom name="floor" type="plane" size="6 6 0.1" material="mat_floor" condim="3" friction="0.8 0.005 0.0001"/>

    <!-- Table -->
    <body name="table" pos="0.55 0.0 0.0">
      <geom name="table_top" type="box" size="0.30 0.22 0.025" pos="0 0 0.675"
            material="mat_table" condim="3" friction="1.2 0.005 0.0001" contype="1" conaffinity="1"/>
      <geom name="leg_fl" type="cylinder" size="0.02 0.325" pos="-0.26 0.18 0.325"
            material="mat_metal" condim="1" contype="1" conaffinity="1"/>
      <geom name="leg_fr" type="cylinder" size="0.02 0.325" pos="-0.26 -0.18 0.325"
            material="mat_metal" condim="1" contype="1" conaffinity="1"/>
      <geom name="leg_bl" type="cylinder" size="0.02 0.325" pos="0.26 0.18 0.325"
            material="mat_metal" condim="1" contype="1" conaffinity="1"/>
      <geom name="leg_br" type="cylinder" size="0.02 0.325" pos="0.26 -0.18 0.325"
            material="mat_metal" condim="1" contype="1" conaffinity="1"/>
    </body>

    <!-- Rubik's cube (any 5.6cm cube -- collision is a single box; six colored
         sticker plates are purely visual (contype/conaffinity 0) so the object
         reads as a cube without needing a textured mesh asset). -->
    <body name="rubiks_cube" pos="0.50 0.0 0.728">
      <joint name="cube_free" type="free"/>
      <geom name="cube_body" type="box" size="0.028 0.028 0.028" material="mat_cube_body" mass="0.09"
            condim="6" friction="1.0 0.01 0.001" contype="1" conaffinity="1"
            solimp="0.99 0.999 0.001" solref="0.01 1"/>
      <site name="cube_grasp_site" type="sphere" size="0.012" pos="0 0 0" rgba="0.0 1.0 0.2 0.6"/>
    </body>

    <!-- Placement target: sits further along the table than the cube
         (clear of it -- cube's far edge is at x=0.528, plate's near edge is
         at x=0.55) so the two objects don't need to move relative to the
         already-tuned head_camera_close pose above. -->
    <body name="plate" pos="0.65 0.0 0.706">
      <geom name="plate_geom" type="cylinder" size="0.11 0.006" material="mat_plate"
            condim="3" friction="0.6 0.005 0.0001" contype="1" conaffinity="1"/>
    </body>

    <!-- Mocap IK Target Marker -->
    <body name="ik_target_marker" pos="0.50 0.0 0.728" mocap="true">
      <geom name="ik_marker_geom" type="sphere" size="0.025" material="mat_target" contype="0" conaffinity="0" group="2"/>
    </body>
  </worldbody>

  <!-- Include G1 robot configuration directly, relying on compiler meshdir to resolve meshes -->
  <include file="../../g1_fixed_manipulation.xml"/>

</mujoco>
