<mujoco model="g1_apple_table_scene">

  <compiler angle="radian" meshdir="../.."/>

  <option timestep="0.002" gravity="0 0 -9.81" solver="CG" iterations="50" tolerance="1e-10"/>

  <visual>
    <quality shadowsize="4096" offsamples="8"/>
    <map shadowclip="0.5" shadowscale="1.5" znear="0.01"/>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0.1 0.1 0.1"/>
    <global offwidth="640" offheight="480"/>
  </visual>

  <asset>
    <!-- Floor: checker pattern -->
    <texture type="2d" name="tex_floor"
             builtin="checker"
             rgb1="0.10 0.10 0.12"
             rgb2="0.16 0.16 0.20"
             width="512" height="512"
             mark="edge" markrgb="0.25 0.25 0.30"/>
    <material name="mat_floor" texture="tex_floor"
              texrepeat="4 4" texuniform="true" reflectance="0.05"/>

    <!-- Table: warm wood tone -->
    <material name="mat_wood" rgba="0.55 0.35 0.18 1.0" shininess="0.15" specular="0.15"/>

    <!-- Table legs: dark metal -->
    <material name="mat_metal" rgba="0.25 0.25 0.28 1.0" shininess="0.6" specular="0.5"/>

    <!-- Apple: bright red -->
    <material name="mat_apple" rgba="0.88 0.10 0.08 1.0" shininess="0.6" specular="0.5"/>

    <!-- Apple stem: brown -->
    <material name="mat_stem" rgba="0.35 0.20 0.08 1.0" shininess="0.1" specular="0.05"/>

    <!-- IK target marker: bright cyan sphere -->
    <material name="mat_target" rgba="0.0 0.9 0.9 0.7" shininess="0.8" specular="0.6"/>

    <!-- End-effector marker: bright yellow -->
    <material name="mat_ee" rgba="1.0 0.9 0.0 0.8" shininess="0.8" specular="0.5"/>
  </asset>

  <worldbody>
    <!-- Lights -->
    <light name="light_key" directional="true" diffuse="0.85 0.85 0.85" specular="0.30 0.30 0.30"
           pos="1.0 -0.5 4.0" dir="-0.3 0.2 -1" castshadow="true"/>

    <light name="light_fill" directional="true" diffuse="0.35 0.35 0.40" specular="0.05 0.05 0.05"
           pos="-2 1 3" dir="1 -0.5 -1" castshadow="false"/>

    <!-- Cameras -->
    <camera name="cam_front" pos="2.2 0.0 1.1" xyaxes="-1 0 0  0 0 1" fovy="50"/>
    <camera name="cam_side" pos="0.0 2.5 1.2" xyaxes="1 0 0  0 -0.3 1" fovy="45"/>
    <camera name="cam_top" pos="0.5 0.0 2.8" xyaxes="1 0 0  0 1 0" fovy="55"/>
    <camera name="cam_wrist" pos="0.5 0.35 0.95" target="apple" fovy="60"/>

    <!-- Floor -->
    <geom name="floor" type="plane" size="6 6 0.1" material="mat_floor" condim="3" friction="0.8 0.005 0.0001"/>

    <!-- Table -->
    <body name="table" pos="0.55 0.0 0.0">
      <geom name="table_top" type="box" size="0.30 0.22 0.025" pos="0 0 0.675"
            material="mat_wood" condim="3" friction="1.2 0.005 0.0001" contype="1" conaffinity="1"/>
      <geom name="leg_fl" type="cylinder" size="0.02 0.325" pos="-0.26 0.18 0.325"
            material="mat_metal" condim="1" contype="1" conaffinity="1"/>
      <geom name="leg_fr" type="cylinder" size="0.02 0.325" pos="-0.26 -0.18 0.325"
            material="mat_metal" condim="1" contype="1" conaffinity="1"/>
      <geom name="leg_bl" type="cylinder" size="0.02 0.325" pos="0.26 0.18 0.325"
            material="mat_metal" condim="1" contype="1" conaffinity="1"/>
      <geom name="leg_br" type="cylinder" size="0.02 0.325" pos="0.26 -0.18 0.325"
            material="mat_metal" condim="1" contype="1" conaffinity="1"/>
    </body>

    <!-- Apple -->
    <body name="apple" pos="0.55 0.0 0.74">
      <joint name="apple_free" type="free"/>
      <geom name="apple_geom" type="sphere" size="0.04" material="mat_apple" mass="0.18" condim="6"
            friction="0.9 0.01 0.001" contype="1" conaffinity="1" solimp="0.99 0.999 0.001" solref="0.01 1"/>
      <geom name="apple_stem" type="capsule" size="0.004 0.012" pos="0 0 0.042" material="mat_stem"
            contype="0" conaffinity="0" mass="0.005"/>
      <site name="apple_grasp_site" type="sphere" size="0.012" pos="0 0 0" rgba="0.0 1.0 0.2 0.6"/>
    </body>

    <!-- Mocap IK Target Marker -->
    <body name="ik_target_marker" pos="0.55 0.0 0.74" mocap="true">
      <geom name="ik_marker_geom" type="sphere" size="0.025" material="mat_target" contype="0" conaffinity="0" group="2"/>
    </body>
  </worldbody>

  <!-- Include G1 robot configuration directly, relying on compiler meshdir to resolve meshes -->
  <include file="../../g1_fixed_manipulation.xml"/>

</mujoco>